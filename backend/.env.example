# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agritech

# Google Earth Engine (optional - backend works without it via STAC fallback)
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_PATH=

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]

# App
APP_NAME=AgriTech Backend
APP_VERSION=0.1.0
DEBUG=true
